# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual envs ---
.venv/
venv/
env/

# --- Build artifacts ---
build/
staging/
dist/
# The PortableApps.com Installer emits <AppID>_<version>.paf.exe into the repo
# root before build.py moves it into dist/; ignore any stray root artifact so an
# interrupted build never leaves a committable one behind.
/*.paf.exe
*.spec.bak

# --- PyInstaller ---
# (paskills.spec IS tracked; only PyInstaller-generated work-dirs are not)
build_pyinstaller/

# --- IDE / OS ---
.idea/
.vscode/
.DS_Store
Thumbs.db
desktop.ini

# --- Logs / outputs (build-time scratch) ---
*.log
.coverage

# --- Local dev overrides ---
.env
.env.*
!.env.example

CmdResult/
Error/

# --- User data (personal bank statements, GnuCash books, outputs) ---
# Data/ is real user data (PII) and stays untracked, EXCEPT the ITR
# Workbook skill's rules registry and *.example.yaml config templates,
# which are safe (no amounts/names/PANs) and meant to ship with the repo
# (2026-07-12-itr-workbook-skill-plan.md section 4.2). Each ancestor
# directory on the path to a kept file must be un-ignored explicitly --
# git won't descend into an ignored directory to find a negated child.
Data/*
!Data/.gitkeep
!Data/itr
Data/itr/*
!Data/itr/rules
!Data/itr/*.example.yaml
Data/itr/rules/*
!Data/itr/rules/*.yaml
ICICI/
outputs/
!outputs/.gitkeep

# --- Bundling logs ---
bundling/launcher-gen/*/Data/
bundling/installer/*/Data/

# --- Runtime artifacts (written by the app at launch, not source) ---
ui_port.json

# --- Ad-hoc dated planning / test files at repo root ---
2026-*.md
2026-*.py
HDFC_BUILD_PLAN.md
PHASE3_USAGE_GUIDE.md
