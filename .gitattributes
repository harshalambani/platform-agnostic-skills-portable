# Git LFS tracking — see spec section 10.5.
# Native binaries (Tesseract, Poppler, qpdf) and OCR language data live under vendor/
# and are tracked via LFS so the repo can be cloned for fully air-gapped builds.

vendor/** filter=lfs diff=lfs merge=lfs -text
*.exe     filter=lfs diff=lfs merge=lfs -text
*.dll     filter=lfs diff=lfs merge=lfs -text
*.traineddata filter=lfs diff=lfs merge=lfs -text

# Normalise text files to LF in the repo, but keep CRLF in the working tree on Windows
*           text=auto
*.py        text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.ini       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary file types that should never be diffed as text
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
*.zip       binary
*.pdf       binary
*.xlsx      binary
*.docx      binary

# Vendored PortableApps.com Installer tool (NSIS + 7zip + graphics). Track the
# whole tree via LFS like vendor/, so its .bmp/.ico/etc. binaries don't bloat
# regular git history. Placed last so it wins precedence for files under it.
bundling/installer/** filter=lfs diff=lfs merge=lfs -text
